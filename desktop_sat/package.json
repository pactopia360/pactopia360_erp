{
  "name": "pactopia360-sat-desktop",
  "version": "0.1.0",
  "description": "Aplicacion de escritorio Windows para descargas SAT de Pactopia360",
  "main": "main.js",
  "author": "PACTOPIA360",
  "license": "UNLICENSED",
  "private": true,
  "productName": "PACTOPIA360 SAT Desktop",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win nsis"
  },
  "build": {
    "appId": "com.pactopia360.satdesktop",
    "productName": "PACTOPIA360 SAT Desktop",
    "compression": "normal",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "src/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "main.js"
    },
    "asar": true,
    "win": {
      "icon": "../public/assets/admin/img/p360_pro.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "PACTOPIA360-SAT-Desktop-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "PACTOPIA360 SAT Desktop",
      "installerIcon": "../public/assets/admin/img/p360_pro.ico",
      "uninstallerIcon": "../public/assets/admin/img/p360_pro.ico",
      "installerHeaderIcon": "../public/assets/admin/img/p360_pro.ico",
      "artifactName": "PACTOPIA360-SAT-Desktop-Setup-${version}.${ext}",
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false,
      "displayLanguageSelector": false,
      "uninstallDisplayName": "PACTOPIA360 SAT Desktop"
    }
  },
  "dependencies": {
    "axios": "^1.7.9",
    "electron-store": "^10.0.1"
  },
  "devDependencies": {
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12"
  }
}